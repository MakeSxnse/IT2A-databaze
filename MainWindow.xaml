<Window x:Class="databaze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:databaze"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dgJidlo"
          Grid.Column="0"
          Margin="0,0,323,0"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          SelectionMode="Single"
          SelectionUnit="FullRow" SelectionChanged="dgJidlo_SelectionChanged" ItemsSource="{Binding Foods}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Název" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="*"/>
                <DataGridTextColumn Header="Množství" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="% zpotřebováno" Binding="{Binding ConsumedPercent}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Evidence jídla" HorizontalAlignment="Left" Margin="537,10,0,0" VerticalAlignment="Top" Background="#FF004796" Foreground="White" FontSize="24" FontWeight="Bold" FontFamily="Cascadia Mono"/>
        <TextBlock HorizontalAlignment="Left" Margin="488,55,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Název"/><Run Language="cs-cz" Text=":" /></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="488,76,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="294" x:Name="tbName"/>
        <TextBox HorizontalAlignment="Left" Margin="488,129,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="294" x:Name="tbType"/>
        <TextBlock HorizontalAlignment="Left" Margin="488,108,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="cs-cz" Text="Druh:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="488,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="40"><Run Language="cs-cz" Text="Počet:"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="488,185,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="294" x:Name="tbQuantity"/>
        <TextBlock HorizontalAlignment="Left" Margin="488,221,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="109"><Run Language="cs-cz" Text="Kolik % se snědlo"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="488,242,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="294" x:Name="tbConsumedPercent"/>
        
        <Button Content="Přidat do tabulky" HorizontalAlignment="Left" Margin="488,287,0,0" VerticalAlignment="Top" Width="294" Click="Add_Click"/>
        <Button Content="Načíst vybrané jídlo" HorizontalAlignment="Left" Margin="488,312,0,0" VerticalAlignment="Top" Width="294" Click="Load_Click"/>
        <Button Content="Upravit stav jídla" HorizontalAlignment="Left" Margin="488,337,0,0" VerticalAlignment="Top" Width="294" Click="Update_Click"/>
        <Button Content="Smazat jídlo" HorizontalAlignment="Left" Margin="488,362,0,0" VerticalAlignment="Top" Width="294" Click="Delete_Click"/>
    </Grid>
</Window>
